From 6a29edf2d3f92b8368d495a1cd8271cc405a0104 Mon Sep 17 00:00:00 2001
From: Nick Xie <nick@khadas.com>
Date: Mon, 2 Feb 2026 11:04:57 +0800
Subject: [PATCH 86/94] WIP: arm64: dts: amlogic: meson-s4-s905y4-khadas-vim1s:
 enable usb host

Signed-off-by: Nick Xie <nick@khadas.com>
---
 .../dts/amlogic/meson-s4-s905y4-khadas-vim1s.dts | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/arch/arm64/boot/dts/amlogic/meson-s4-s905y4-khadas-vim1s.dts b/arch/arm64/boot/dts/amlogic/meson-s4-s905y4-khadas-vim1s.dts
index fdee50aeea6a..a1b2e01e4fde 100644
--- a/arch/arm64/boot/dts/amlogic/meson-s4-s905y4-khadas-vim1s.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-s4-s905y4-khadas-vim1s.dts
@@ -378,3 +378,19 @@ bluetooth {
 &uart_b {
 	status = "okay";
 };
+
+&usb {
+	status = "okay";
+};
+
+&usb2_phy0 {
+	status = "okay";
+	portnum = <2>;
+};
+
+&usb2_phy1 {
+	status = "okay";
+	portnum = <2>;
+	gpio-vbus-power = "GPIOH_6";
+	gpios = <&gpio GPIOH_6 GPIO_ACTIVE_HIGH>;
+};
-- 
