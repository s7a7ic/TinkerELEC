function custom_post_commit() {
  echo "Starting revision update of dependant addons"
  # do not change the version, just increment the addon
  export commit_msg="audiodecoder.fluidsynth: update fluidsynth to ${pkgver}"
  export commit_body="\n\n- fluidsynth: ${pkgver}"
  ${progname} audiodecoder.fluidsynth $(get_pkg_version audiodecoder.fluidsynth)
}
