# zidoo v12 remote
evdev:input:b0005v5A44p5A44*
 KEYBOARD_KEY_7001e=one #1
 KEYBOARD_KEY_7001f=two #2
 KEYBOARD_KEY_70020=three #3
 KEYBOARD_KEY_70021=four #4
 KEYBOARD_KEY_70022=five #5
 KEYBOARD_KEY_70023=six #6
 KEYBOARD_KEY_70024=seven #7
 KEYBOARD_KEY_70025=eight #8
 KEYBOARD_KEY_70026=nine #9
 KEYBOARD_KEY_70027=zero #0
 KEYBOARD_KEY_7002a=backspace
 KEYBOARD_KEY_7003a=l #sub
 KEYBOARD_KEY_70045=m #square key with lines
 KEYBOARD_KEY_7009a=o #tv out
 KEYBOARD_KEY_700b7=power #tv out green
 KEYBOARD_KEY_c006d=c #zoom
 KEYBOARD_KEY_c00bc=repeat
 KEYBOARD_KEY_c01bd=i #info
 KEYBOARD_KEY_c01b7=leftquote #audio
 KEYBOARD_KEY_c00e2=volume_mute
 KEYBOARD_KEY_c00e9=period #vol-up
 KEYBOARD_KEY_c00ea=comma #vol-down
