#!/bin/sh

# SPDX-License-Identifier: GPL-2.0-only
# Copyright (C) 2018-present Team LibreELEC (https://libreelec.tv)

. /etc/profile
oe_setup_addon service.snapclient

. /etc/os-release
case "$DISTRO_ARCH" in
  RPi*.arm)
    if [ "$sc_a" == "true" ]; then
      ALSA="/proc/asound/ALSA"
      if [ ! -e "$ALSA" ]; then
        echo "Starting Raspberry Pi onboard audio"
        dtparam audio=on
        sleep 1
      fi
      if [ -e "$ALSA" ]; then
        echo "Setting Raspberry Pi onboard audio playback route"
        index="$(readlink $ALSA)"
        index="${index##*card}"
        amixer -c "$index" cset name="PCM Playback Route" "$sc_r"
      fi
    fi
    ;;
esac

ARGS=""
[ -n "$sc_addr" ] && ARGS="$ARGS --host $sc_addr"
[ -n "$sc_h" ] && ARGS="$ARGS --hostID '$sc_h'"
[ -n "$sc_l" ] && ARGS="$ARGS --latency $sc_l"
[ -n "$sc_p" ] && ARGS="$ARGS --port $sc_p"
[ -n "$sc_s" ] && ARGS="$ARGS --soundcard $sc_s"

# delay service statup on boot to prevent alsa issue
if [ -n "$sc_delay" ]; then
  [ $(journalctl -u service.snapclient | grep "Started" | wc -l) -eq 1 ] && \
  sleep $sc_delay
fi

HOME="$ADDON_HOME" \
nice -n "$sc_n" \
/bin/sh -c "snapclient $ARGS > /dev/null"
