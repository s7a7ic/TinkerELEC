if [ -n "${KODI_KEYBOARD_LAYOUT}" ]; then
  export XKB_DEFAULT_LAYOUT="${KODI_KEYBOARD_LAYOUT}"
fi

export XDG_RUNTIME_DIR="/run/user/$(id -u)"
mkdir -p "${XDG_RUNTIME_DIR}"
chmod 0700 "${XDG_RUNTIME_DIR}"

mydir=$(dirname "$0")

dbus-run-session -- \
  "${mydir}/seatd-launch" -p "${mydir}/seatd" -- \
  "${mydir}/cage" -- \
  "${mydir}/wayland-session-helper" "$@"
