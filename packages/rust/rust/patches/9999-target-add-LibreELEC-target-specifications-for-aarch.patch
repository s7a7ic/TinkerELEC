diff --git a/compiler/rustc_target/src/spec/targets/x86_64_libreelec_linux_gnu.rs b/compiler/rustc_target/src/spec/targets/x86_64_libreelec_linux_gnu.rs
new file mode 100644
index 00000000000..2d32c689ad6
--- /dev/null
+++ b/compiler/rustc_target/src/spec/targets/x86_64_libreelec_linux_gnu.rs
@@ -0,0 +1,52 @@
+use crate::spec::{
+    Arch, Cc, LinkerFlavor, Lld, SanitizerSet, StackProbeType, Target, TargetMetadata, base,
+};
+
+pub(crate) fn target() -> Target {
+    let mut base = base::linux_gnu::opts();
+
+    // ── Upstream x86_64-unknown-linux-gnu defaults ────────────────────────
+    base.cpu = "x86-64".into();
+    base.plt_by_default = false;
+    base.max_atomic_width = Some(64);
+    base.add_pre_link_args(LinkerFlavor::Gnu(Cc::Yes, Lld::No), &["-m64"]);
+    base.stack_probes = StackProbeType::Inline;
+    base.static_position_independent_executables = true;
+    base.supported_sanitizers = SanitizerSet::ADDRESS
+        | SanitizerSet::CFI
+        | SanitizerSet::KCFI
+        | SanitizerSet::DATAFLOW
+        | SanitizerSet::LEAK
+        | SanitizerSet::MEMORY
+        | SanitizerSet::SAFESTACK
+        | SanitizerSet::THREAD
+        | SanitizerSet::REALTIME;
+    base.supports_xray = true;
+
+    // ── LibreELEC overrides ───────────────────────────────────────────────
+
+    // Call-based stack probes — conservative choice for appliance hardware
+    base.stack_probes = StackProbeType::Call;
+
+    // Reduced sanitizer set — drops what LibreELEC's toolchain can't support
+    base.supported_sanitizers = SanitizerSet::ADDRESS
+        | SanitizerSet::CFI
+        | SanitizerSet::LEAK
+        | SanitizerSet::MEMORY
+        | SanitizerSet::THREAD;
+
+    Target {
+        llvm_target: "x86_64-unknown-linux-gnu".into(),
+        metadata: TargetMetadata {
+            description: Some("64-bit Linux for LibreELEC (kernel 3.2+, glibc 2.17+)".into()),
+            tier: Some(3),
+            host_tools: Some(false),
+            std: Some(true),
+        },
+        pointer_width: 64,
+        data_layout:
+            "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128".into(),
+        arch: Arch::X86_64,
+        options: base,
+    }
+}
