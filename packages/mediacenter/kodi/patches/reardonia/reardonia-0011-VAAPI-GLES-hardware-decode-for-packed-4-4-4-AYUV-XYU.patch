From 2fbbf4b96541ee5ce673728d0f6b692c699b0166 Mon Sep 17 00:00:00 2001
From: reardonia <2925104+reardonia@users.noreply.github.com>
Date: Fri, 8 May 2026 10:05:25 -0400
Subject: [PATCH 11/21] VAAPI/GLES: hardware decode for packed 4:4:4 (AYUV,
 XYUV, Y410, Y412, Y416)

Cover HEVC Main444 / Main444_10 / Main444_12 and VP9 Profile 1 / Profile
3 4:4:4 on GBM + GLES by wiring up the packed surface fourccs Intel iHD
produces: AYUV / XYUV (8-bit), Y410 (10-bit), Y412 (12-bit), Y416
(16-bit storage).

Shader: SHADER_AYUV / Y410 / Y412 added. The XBMC_AYUV branch samples
DRM_FORMAT_AYUV (8-bit V/U/Y/A) imported as GL_RGBA8 and remaps RGBA to
Y/U/V. The XBMC_Y410 branch samples DRM_FORMAT_Y410 imported as
GL_RGB10_A2 (RGBA = U/Y/V/A per the format's standard layout). The
XBMC_Y412 branch samples DRM_FORMAT_Y412 / Y416 imported as GL_RGBA16
(RGBA = U/Y/V/A).

kVaFormatTable extends with AYUV, XYUV, Y410, Y412, Y416 entries paired
with their AVPixelFormat equivalents (VUYA, VUYX, XV30, XV36, XV48).
Note: AVPixelFormat naming does not match VAAPI fourcc naming for 4:4:4
- VA_FOURCC_AYUV has byte order V,U,Y,A in memory (matches AV_PIX_FMT_
VUYA, not AV_PIX_FMT_AYUV which is byte order A,Y,U,V).

CDecoder::Open: HEVC REXT 4:4:4 dispatch by bit depth (Main444 /
Main444_10 / Main444_12), gated on caps and pix_fmt. VP9 Profile 1
(8-bit) and Profile 3 (10/12-bit) accept 4:4:4 pix_fmts only - VAAPI
does not split the VP9 profile by chroma so 4:2:2 VP9 falls through to
software decode.

CDecoder::ConfigVAAPI: VA_RT_FORMAT_YUV444 / YUV444_10 / YUV444_12
selection, picking AYUV (or XYUV fallback) for 8-bit, Y410 for 10-bit,
Y412 (or Y416 fallback) for 12-bit.

CRendererVAAPIGLES::GetShaderFormat dispatches the new fourccs to the
matching SHADER_AYUV / Y410 / Y412 paths. Texture geometry remains
single-plane full-resolution since 4:4:4 has one full YUV sample per
texel.

Fixes #27745 for Intel iHD.
---
 .../shaders/GLES/2.0/gles_yuv2rgb_basic.frag  | 23 +++++++
 .../VideoPlayer/DVDCodecs/Video/VAAPI.cpp     | 65 ++++++++++++++++++-
 .../cores/VideoPlayer/DVDCodecs/Video/VAAPI.h |  5 ++
 .../HwDecRender/RendererVAAPIGLES.cpp         | 14 +++-
 .../VideoShaders/ShaderFormats.h              |  6 ++
 .../VideoShaders/YUV2RGBShaderGLES.cpp        |  6 ++
 6 files changed, 116 insertions(+), 3 deletions(-)

diff --git a/system/shaders/GLES/2.0/gles_yuv2rgb_basic.frag b/system/shaders/GLES/2.0/gles_yuv2rgb_basic.frag
index 9862dcbb8d..7893e305ef 100644
--- a/system/shaders/GLES/2.0/gles_yuv2rgb_basic.frag
+++ b/system/shaders/GLES/2.0/gles_yuv2rgb_basic.frag
@@ -114,6 +114,29 @@ void main()
 
   yuv = vec4(outY, outUV, 1.0);
 
+#elif defined(XBMC_AYUV)
+
+  // Packed 4:4:4 in 8-bit channels (AYUV, XYUV). DRM_FORMAT_AYUV stores
+  // bytes V, U, Y, A in memory; EGL imports as GL_RGBA8 so RGBA = V, U, Y,
+  // alpha. Shader sees one full-resolution YUV sample per texel.
+  vec4 t = texture2D(m_sampY, m_cordY);
+  yuv = vec4(t.b, t.g, t.r, 1.0);
+
+#elif defined(XBMC_Y410)
+
+  // Packed 4:4:4 10-bit in a 32-bit word (DRM_FORMAT_Y410). EGL imports as
+  // GL_RGB10_A2; the format's standard bit layout puts A2 V10 U10 Y10
+  // little-endian, which surfaces as RGBA = U, Y, V, A after import.
+  vec4 t = texture2D(m_sampY, m_cordY);
+  yuv = vec4(t.g, t.r, t.b, 1.0);
+
+#elif defined(XBMC_Y412)
+
+  // Packed 4:4:4 in 16-bit channels (Y412 12-bit, Y416 16-bit). EGL imports
+  // as GL_RGBA16 with channel order RGBA = U, Y, V, A.
+  vec4 t = texture2D(m_sampY, m_cordY);
+  yuv = vec4(t.g, t.r, t.b, 1.0);
+
 #endif
 
   rgb = m_yuvmat * yuv;
diff --git a/xbmc/cores/VideoPlayer/DVDCodecs/Video/VAAPI.cpp b/xbmc/cores/VideoPlayer/DVDCodecs/Video/VAAPI.cpp
index 9033a011fb..d6dfda2b32 100644
--- a/xbmc/cores/VideoPlayer/DVDCodecs/Video/VAAPI.cpp
+++ b/xbmc/cores/VideoPlayer/DVDCodecs/Video/VAAPI.cpp
@@ -714,6 +714,23 @@ bool CDecoder::Open(AVCodecContext* avctx, AVCodecContext* mainctx, const enum A
       {
         profile = VAProfileHEVCMain422_12;
       }
+      else if (avctx->profile == AV_PROFILE_HEVC_REXT && m_vaapiConfig.bitDepth == 8 &&
+               chroma == 444 &&
+               (m_capFormats.Supports(AV_PIX_FMT_VUYA) || m_capFormats.Supports(AV_PIX_FMT_VUYX)))
+      {
+        profile = VAProfileHEVCMain444;
+      }
+      else if (avctx->profile == AV_PROFILE_HEVC_REXT && m_vaapiConfig.bitDepth == 10 &&
+               chroma == 444 && m_capFormats.Supports(AV_PIX_FMT_XV30))
+      {
+        profile = VAProfileHEVCMain444_10;
+      }
+      else if (avctx->profile == AV_PROFILE_HEVC_REXT && m_vaapiConfig.bitDepth == 12 &&
+               chroma == 444 &&
+               (m_capFormats.Supports(AV_PIX_FMT_XV36) || m_capFormats.Supports(AV_PIX_FMT_XV48)))
+      {
+        profile = VAProfileHEVCMain444_12;
+      }
       else
         profile = VAProfileNone;
       if (!m_vaapiConfig.context->SupportsProfile(profile))
@@ -729,10 +746,31 @@ bool CDecoder::Open(AVCodecContext* avctx, AVCodecContext* mainctx, const enum A
     }
     case AV_CODEC_ID_VP9:
     {
+      // VP9 profiles vary chroma subsampling and bit depth orthogonally:
+      //   Profile 0: 4:2:0  8-bit
+      //   Profile 1: 4:2:2 / 4:4:4  8-bit
+      //   Profile 2: 4:2:0  10/12-bit
+      //   Profile 3: 4:2:2 / 4:4:4  10/12-bit
+      // VAAPI does not split by chroma; the VP9 profile constants cover both
+      // 4:2:2 and 4:4:4 inside Profile 1 / Profile 3, with the surface fourcc
+      // selected per the actual content's pix_fmt. Intel iHD only produces
+      // 4:4:4 surfaces for VP9 1/3, so 4:2:2 VP9 falls through to SW.
       if (avctx->profile == AV_PROFILE_VP9_0)
         profile = VAProfileVP9Profile0;
       else if (avctx->profile == AV_PROFILE_VP9_2)
         profile = VAProfileVP9Profile2;
+      else if (avctx->profile == AV_PROFILE_VP9_1 && chroma == 444 &&
+               (m_capFormats.Supports(AV_PIX_FMT_VUYA) || m_capFormats.Supports(AV_PIX_FMT_VUYX)))
+      {
+        profile = VAProfileVP9Profile1;
+      }
+      else if (avctx->profile == AV_PROFILE_VP9_3 && chroma == 444 &&
+               ((m_vaapiConfig.bitDepth == 10 && m_capFormats.Supports(AV_PIX_FMT_XV30)) ||
+                (m_vaapiConfig.bitDepth == 12 && (m_capFormats.Supports(AV_PIX_FMT_XV36) ||
+                                                  m_capFormats.Supports(AV_PIX_FMT_XV48)))))
+      {
+        profile = VAProfileVP9Profile3;
+      }
       else
         profile = VAProfileNone;
       if (!m_vaapiConfig.context->SupportsProfile(profile))
@@ -1207,7 +1245,8 @@ bool CDecoder::ConfigVAAPI()
   m_vaapiConfig.attrib = m_vaapiConfig.context->GetAttrib(m_vaapiConfig.profile);
   unsigned int validFormats = VA_RT_FORMAT_YUV420 | VA_RT_FORMAT_YUV420_10BPP |
                               VA_RT_FORMAT_YUV420_12 | VA_RT_FORMAT_YUV422_10 |
-                              VA_RT_FORMAT_YUV422_12;
+                              VA_RT_FORMAT_YUV422_12 | VA_RT_FORMAT_YUV444 |
+                              VA_RT_FORMAT_YUV444_10 | VA_RT_FORMAT_YUV444_12;
   if ((m_vaapiConfig.attrib.value & validFormats) == 0)
   {
     CLog::Log(LOGERROR, "VAAPI - invalid yuv format {:x}", m_vaapiConfig.attrib.value);
@@ -1254,6 +1293,30 @@ bool CDecoder::ConfigVAAPI()
     format = VA_RT_FORMAT_YUV422_12;
     pixelFormat = m_capFormats.Supports(AV_PIX_FMT_Y212) ? VA_FOURCC_Y212 : VA_FOURCC_Y216;
   }
+  else if ((m_vaapiConfig.profile == VAProfileHEVCMain444 ||
+            m_vaapiConfig.profile == VAProfileVP9Profile1) &&
+           m_vaapiConfig.bitDepth == 8)
+  {
+    // AYUV is the standard 4:4:4 8-bit fourcc; XYUV is identical bytes
+    // with alpha ignored, used by some VAAPI versions.
+    format = VA_RT_FORMAT_YUV444;
+    pixelFormat = m_capFormats.Supports(AV_PIX_FMT_VUYA) ? VA_FOURCC_AYUV : VA_FOURCC_XYUV;
+  }
+  else if ((m_vaapiConfig.profile == VAProfileHEVCMain444_10 ||
+            m_vaapiConfig.profile == VAProfileVP9Profile3) &&
+           m_vaapiConfig.bitDepth == 10)
+  {
+    format = VA_RT_FORMAT_YUV444_10;
+    pixelFormat = VA_FOURCC_Y410;
+  }
+  else if ((m_vaapiConfig.profile == VAProfileHEVCMain444_12 ||
+            m_vaapiConfig.profile == VAProfileVP9Profile3) &&
+           m_vaapiConfig.bitDepth == 12)
+  {
+    // Y412 is the 12-bit-native fourcc; Y416 is the 16-bit-storage fallback.
+    format = VA_RT_FORMAT_YUV444_12;
+    pixelFormat = m_capFormats.Supports(AV_PIX_FMT_XV36) ? VA_FOURCC_Y412 : VA_FOURCC_Y416;
+  }
 
   VASurfaceAttrib attribs[1], *attrib;
   attrib = attribs;
diff --git a/xbmc/cores/VideoPlayer/DVDCodecs/Video/VAAPI.h b/xbmc/cores/VideoPlayer/DVDCodecs/Video/VAAPI.h
index 5053bc6698..2a74eade89 100644
--- a/xbmc/cores/VideoPlayer/DVDCodecs/Video/VAAPI.h
+++ b/xbmc/cores/VideoPlayer/DVDCodecs/Video/VAAPI.h
@@ -466,6 +466,11 @@ inline constexpr VaFormatEntry kVaFormatTable[] = {
     {VA_FOURCC_Y210, VA_RT_FORMAT_YUV422_10, AV_PIX_FMT_Y210},
     {VA_FOURCC_Y212, VA_RT_FORMAT_YUV422_12, AV_PIX_FMT_Y212},
     {VA_FOURCC_Y216, VA_RT_FORMAT_YUV422_12, AV_PIX_FMT_Y216},
+    {VA_FOURCC_AYUV, VA_RT_FORMAT_YUV444, AV_PIX_FMT_VUYA},
+    {VA_FOURCC_XYUV, VA_RT_FORMAT_YUV444, AV_PIX_FMT_VUYX},
+    {VA_FOURCC_Y410, VA_RT_FORMAT_YUV444_10, AV_PIX_FMT_XV30},
+    {VA_FOURCC_Y412, VA_RT_FORMAT_YUV444_12, AV_PIX_FMT_XV36},
+    {VA_FOURCC_Y416, VA_RT_FORMAT_YUV444_12, AV_PIX_FMT_XV48},
 };
 
 /*!
diff --git a/xbmc/cores/VideoPlayer/VideoRenderers/HwDecRender/RendererVAAPIGLES.cpp b/xbmc/cores/VideoPlayer/VideoRenderers/HwDecRender/RendererVAAPIGLES.cpp
index f98a59c582..0fe6d9ce20 100644
--- a/xbmc/cores/VideoPlayer/VideoRenderers/HwDecRender/RendererVAAPIGLES.cpp
+++ b/xbmc/cores/VideoPlayer/VideoRenderers/HwDecRender/RendererVAAPIGLES.cpp
@@ -157,8 +157,8 @@ EShaderFormat CRendererVAAPIGLES::GetShaderFormat()
   // P012 / P016) all share SHADER_NV12_RRG; Mesa imports their DMA-BUF as
   // GL_R16 / GL_RG16 textures whose normalized 0..1 sampled floats span
   // the full range regardless of underlying bit depth, so one shader
-  // covers all 4:2:0 bit depths. Packed 4:2:2 has its own shader because
-  // its channel layout differs.
+  // covers all 4:2:0 bit depths. Packed 4:2:2 and 4:4:4 each have their
+  // own shader because their channel layouts differ.
   switch (m_vaapiFourcc)
   {
     case VA_FOURCC_NV12:
@@ -170,6 +170,16 @@ EShaderFormat CRendererVAAPIGLES::GetShaderFormat()
     case VA_FOURCC_Y212:
     case VA_FOURCC_Y216:
       return SHADER_Y210;
+    case VA_FOURCC_AYUV:
+#ifdef VA_FOURCC_XYUV
+    case VA_FOURCC_XYUV:
+#endif
+      return SHADER_AYUV;
+    case VA_FOURCC_Y410:
+      return SHADER_Y410;
+    case VA_FOURCC_Y412:
+    case VA_FOURCC_Y416:
+      return SHADER_Y412;
     default:
       CLog::Log(LOGDEBUG, "CRendererVAAPIGLES::GetShaderFormat - unrecognized fourcc: {:#x}",
                 m_vaapiFourcc);
diff --git a/xbmc/cores/VideoPlayer/VideoRenderers/VideoShaders/ShaderFormats.h b/xbmc/cores/VideoPlayer/VideoRenderers/VideoShaders/ShaderFormats.h
index 8a58d94c1d..69119669ec 100644
--- a/xbmc/cores/VideoPlayer/VideoRenderers/VideoShaders/ShaderFormats.h
+++ b/xbmc/cores/VideoPlayer/VideoRenderers/VideoShaders/ShaderFormats.h
@@ -26,6 +26,9 @@ enum EShaderFormat
   SHADER_UYVY,
   SHADER_NV12_RRG,
   SHADER_Y210, // packed 4:2:2 in GL_RGBA16 (Y210 / Y212 / Y216)
+  SHADER_AYUV, // packed 4:4:4 in GL_RGBA8  (AYUV / XYUV)
+  SHADER_Y410, // packed 4:4:4 in GL_RGB10_A2 (Y410)
+  SHADER_Y412, // packed 4:4:4 in GL_RGBA16 (Y412 / Y416)
   SHADER_MAX,
 };
 
@@ -56,6 +59,9 @@ private:
       {SHADER_UYVY, "UYVY"},
       {SHADER_NV12_RRG, "NV12 red/red/green"},
       {SHADER_Y210, "Y210 packed 4:2:2"},
+      {SHADER_AYUV, "AYUV packed 4:4:4"},
+      {SHADER_Y410, "Y410 packed 4:4:4 10-bit"},
+      {SHADER_Y412, "Y412 packed 4:4:4 12/16-bit"},
   });
 
   static_assert(SHADER_MAX == shaderFormatMap.size(),
diff --git a/xbmc/cores/VideoPlayer/VideoRenderers/VideoShaders/YUV2RGBShaderGLES.cpp b/xbmc/cores/VideoPlayer/VideoRenderers/VideoShaders/YUV2RGBShaderGLES.cpp
index f6b159c9f0..c6572944a2 100644
--- a/xbmc/cores/VideoPlayer/VideoRenderers/VideoShaders/YUV2RGBShaderGLES.cpp
+++ b/xbmc/cores/VideoPlayer/VideoRenderers/VideoShaders/YUV2RGBShaderGLES.cpp
@@ -58,6 +58,12 @@ BaseYUV2RGBGLSLShader::BaseYUV2RGBGLSLShader(EShaderFormat format,
     m_defines += "#define XBMC_UYVY\n";
   else if (m_format == SHADER_Y210)
     m_defines += "#define XBMC_Y210\n";
+  else if (m_format == SHADER_AYUV)
+    m_defines += "#define XBMC_AYUV\n";
+  else if (m_format == SHADER_Y410)
+    m_defines += "#define XBMC_Y410\n";
+  else if (m_format == SHADER_Y412)
+    m_defines += "#define XBMC_Y412\n";
   else
     CLog::Log(LOGERROR, "GLES: BaseYUV2RGBGLSLShader - unsupported format {}", m_format);
 
