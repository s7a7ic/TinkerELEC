From debf5fc8f8a0877dfb53de486488c6e3dd23dcc4 Mon Sep 17 00:00:00 2001
From: reardonia <2925104+reardonia@users.noreply.github.com>
Date: Sun, 31 May 2026 09:26:34 -0400
Subject: [PATCH 22/23] GBM: restore headless boot path

CWinSystemGbmEGLContext::ChooseEGLConfig filters m_output_formats by
format.active. COffScreenModeSetting::InitDrm skips the plane scan
that flags formats active, so every candidate is rejected and EGL
context creation fails -- Kodi exits with "unable to init windowing
system" when no DRM connector is connected.

Two-part fix:

* OffScreenModeSetting: mark AR24 (DRM_FORMAT_ARGB8888) active
  explicitly so ChooseEGLConfig finds a candidate. EGL allocates a
  real GBM-backed surface for the GUI to render into; nothing is
  scanned out.

* WinSystemGbmEGLContext::CreateNewWindow: skip FindGuiPlane when
  there is no CRTC. FindGuiPlane's purpose is binding a scanout
  plane; with no CRTC there is nothing to bind. Skipping preserves
  its post-condition that m_gui_plane is non-null on return-true by
  not calling it at all when there is nothing to assign.

After: Kodi boots to the GUI in offscreen mode (rendering to a
buffer nothing scans out), JSON-RPC and webserver are reachable,
audio works. Restores behavior originally added in PR #14125
(a1rwulf, 2018) that regressed when ChooseEGLConfig was factored
out of InitWindowSystemEGL.
---
 xbmc/windowing/gbm/WinSystemGbmEGLContext.cpp   |  5 ++++-
 xbmc/windowing/gbm/drm/OffScreenModeSetting.cpp | 11 +++++++++++
 2 files changed, 15 insertions(+), 1 deletion(-)

diff --git a/xbmc/windowing/gbm/WinSystemGbmEGLContext.cpp b/xbmc/windowing/gbm/WinSystemGbmEGLContext.cpp
index 801009c91b..6f19a9db3f 100644
--- a/xbmc/windowing/gbm/WinSystemGbmEGLContext.cpp
+++ b/xbmc/windowing/gbm/WinSystemGbmEGLContext.cpp
@@ -171,7 +171,10 @@ bool CWinSystemGbmEGLContext::CreateNewWindow(const std::string& name,
 #else
   uint64_t modifier = DRM_FORMAT_MOD_LINEAR;
 #endif
-  if (!m_DRM->FindGuiPlane(gbm_bo_get_format(bo), modifier))
+  // Offscreen has no CRTC and no scanout planes; FindGuiPlane has nothing to
+  // assign, so skip the call rather than violate its post-condition that
+  // m_gui_plane is set on success.
+  if (m_DRM->GetCrtc() && !m_DRM->FindGuiPlane(gbm_bo_get_format(bo), modifier))
   {
     return false;
   }
diff --git a/xbmc/windowing/gbm/drm/OffScreenModeSetting.cpp b/xbmc/windowing/gbm/drm/OffScreenModeSetting.cpp
index 8e32b107a0..b2b6468d39 100644
--- a/xbmc/windowing/gbm/drm/OffScreenModeSetting.cpp
+++ b/xbmc/windowing/gbm/drm/OffScreenModeSetting.cpp
@@ -10,6 +10,8 @@
 
 #include "utils/log.h"
 
+#include <algorithm>
+
 using namespace KODI::WINDOWING::GBM;
 
 namespace
@@ -24,6 +26,15 @@ bool COffScreenModeSetting::InitDrm()
   if (!CDRMUtils::OpenDrm(false))
     return false;
 
+  // No real KMS planes exist offscreen, so the plane-scanning loop in
+  // CDRMUtils::InitDrm that flags each outputformat as active never runs.
+  // Activate AR24 here so CWinSystemGbmEGLContext::ChooseEGLConfig has a
+  // candidate and EGL context creation can proceed.
+  auto& formats = GetOutputFormats();
+  auto it = std::ranges::find(formats, DRM_FORMAT_ARGB8888, &outputformat::drm);
+  if (it != formats.end())
+    it->active = true;
+
   CLog::LogF(LOGDEBUG, "initialized offscreen DRM");
   return true;
 }
