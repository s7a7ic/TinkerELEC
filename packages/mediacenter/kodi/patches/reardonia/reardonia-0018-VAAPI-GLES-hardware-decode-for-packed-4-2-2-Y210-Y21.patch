     return *this;
   };
 
@@ -250,6 +255,9 @@ struct CVaapiProcessedPicture
   int id;
   CPostproc *source = nullptr;
   bool crop = false;
+  // VA fourcc of the underlying surface. Set by COutput from
+  // CVaapiConfig::pixelFormat.
