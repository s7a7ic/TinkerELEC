-    if (winSystem->SetHDR(&picture))
-      winSystem->SetGuiCompositing(picture.color_transfer);
-  }
+  if (winSystem->SetHDR(&picture))
+    winSystem->SetGuiCompositing(picture.color_transfer);
 
   std::optional<uint64_t> colorEncoding =
       plane->GetPropertyEnumValue("COLOR_ENCODING", GetColorEncoding(picture));
