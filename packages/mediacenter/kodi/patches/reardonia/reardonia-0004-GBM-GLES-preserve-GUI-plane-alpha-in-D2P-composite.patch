From aa4ea81bf9dcce4bebf95b22656fb48311434572 Mon Sep 17 00:00:00 2001
From: reardonia <2925104+reardonia@users.noreply.github.com>
Date: Sun, 17 May 2026 00:14:31 -0400
Subject: [PATCH 04/18] GBM/GLES: preserve GUI plane alpha in D2P composite

In Direct-to-Plane (D2P) rendering, the display controller composites the
GUI plane over the video plane using the GUI plane's stored alpha channel.
That stored alpha must match the alpha of GUI elements rendered into the
FBO -- if it does not, translucent GUI elements composite at the wrong
opacity against the underlying video.

The default glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA) applies the
same factors to both RGB and alpha:

  final.a = src.a * src.a + dst.a * (1 - src.a)

The backbuffer was cleared to alpha = 0, so this reduces to src.a^2. A
50% translucent GUI element gets stored as 25% alpha; the hardware then
composites it at 25% opacity and video bleeds through too strongly.

Use glBlendFuncSeparate to leave RGB blending untouched while writing
src.a through verbatim. Only do this when both video and GUI planes are
active -- in single-plane mode nothing reads the framebuffer alpha so the
existing path is unchanged.
---
 xbmc/windowing/gbm/WinSystemGbmGLESContext.cpp | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/xbmc/windowing/gbm/WinSystemGbmGLESContext.cpp b/xbmc/windowing/gbm/WinSystemGbmGLESContext.cpp
index 6ad94cf060..3e59ea8e38 100644
--- a/xbmc/windowing/gbm/WinSystemGbmGLESContext.cpp
+++ b/xbmc/windowing/gbm/WinSystemGbmGLESContext.cpp
@@ -308,7 +308,16 @@ void CWinSystemGbmGLESContext::CompositeGui()
   glBindTexture(GL_TEXTURE_2D, m_guiFbo.Texture());
 
   glEnable(GL_BLEND);
-  glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
+
+  // In D2P, the GUI plane is composited against a separate video plane by
+  // the display HW. The default glBlendFunc also blends the alpha channel,
+  // leaving the GUI plane buffer with src.a^2; the hardware composite then
+  // reads that squared alpha and translucent GUI pixels render at the
+  // wrong opacity. Replace the stored alpha so the hardware sees src.a.
+  if (m_DRM->GetVideoPlane() && m_DRM->GetGuiPlane())
+    glBlendFuncSeparate(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA, GL_ONE, GL_ZERO);
+  else
+    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
 
   // set up orthographic projection (screen coords, Y-down)
   float w = static_cast<float>(m_guiFboWidth);
